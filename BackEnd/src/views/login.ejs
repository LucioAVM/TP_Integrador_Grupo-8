<!DOCTYPE html>
<html lang="es">
  <%- include('partials/head.ejs') %>
  <body class="bg-dark login-page">
    <div class="login-theme-wrap">
      <button id="toggle-theme-btn" class="btn btn-sm btn-outline-light fenrir-theme-btn admin-theme-btn" type="button" title="Cambiar modo" aria-label="Cambiar tema">
        <i class="bi bi-moon-stars-fill"></i>
      </button>
    </div>

    <div class="login-shell">
      <main class="login-card fenrir-panel">
        <div class="fenrir-panel-body">
          <img src="/assets/img/favicon.png" alt="Fenrir 3D" class="login-logo" />
          <p class="fenrir-eyebrow text-center mb-1">Panel administrador</p>
          <h1 class="login-title text-center mb-3">Fenrir 3D</h1>

          <% if (error) { %>
          <div class="alert alert-danger" role="alert"><%= error %></div>
          <% } %>

          <form method="POST" action="/login" id="login-form" class="form-admin">
            <div class="mb-3">
              <label class="form-label" for="email">Correo</label>
              <input
                type="email"
                id="email"
                name="email"
                class="form-control"
                placeholder="admin@admin.com"
                required
              />
            </div>
            <div class="mb-3">
              <label class="form-label" for="password">Contraseña</label>
              <input
                type="password"
                id="password"
                name="password"
                class="form-control"
                placeholder="••••••••"
                required
              />
            </div>
            <button type="submit" class="btn btn-admin-primary w-100">
              <i class="bi bi-box-arrow-in-right me-1"></i> Ingresar
            </button>
            <button
              type="button"
              class="btn btn-fenrir-secondary w-100 mt-2"
              onclick="autocompletar()"
            >
              <i class="bi bi-lightning-charge me-1"></i> Acceso rápido
            </button>
          </form>
        </div>
      </main>

      <p class="login-footer mb-0">© 2025 Fenrir 3D — Administración</p>
    </div>

    <script type="module" src="/assets/js/adminThemeInit.js"></script>
    <script>
      function autocompletar() {
        const emailField = document.querySelector('[name="email"]');
        const passwordField = document.querySelector('[name="password"]');
        if (emailField && passwordField) {
          emailField.value = "admin@admin.com";
          passwordField.value = "admin123";
        }
      }
    </script>
  </body>
</html>
