<!DOCTYPE html>
<html lang="es">
  <%- include('partials/head.ejs') %>
  <body class="bg-dark admin-root">
    <%- include('partials/nav.ejs', { activePage: 'dashboard' }) %>
    <main class="container my-4">
      <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-2 mb-3">
        <div>
          <p class="fenrir-eyebrow mb-1">Panel admin</p>
          <h2 class="admin-page-title h4 mb-0">Gestión de productos</h2>
        </div>
        <div class="dashboard-actions">
          <a href="/crearProducto" class="btn btn-admin-primary">
            <i class="bi bi-plus-lg me-1"></i> Nuevo
          </a>
        </div>
      </div>

      <div class="row g-3 mb-4">
        <div class="col-12 col-md-4">
          <div class="card admin-card kpi-card border-top-primary h-100">
            <div class="card-body">
              <p class="kpi-label mb-1">Total Productos</p>
              <p class="kpi-value mb-0"><%= totalProductos %></p>
            </div>
          </div>
        </div>
        <div class="col-12 col-md-4">
          <div class="card admin-card kpi-card border-top-success h-100">
            <div class="card-body">
              <p class="kpi-label mb-1">Total Ventas</p>
              <p class="kpi-value mb-0"><%= totalVentas %></p>
            </div>
          </div>
        </div>
        <div class="col-12 col-md-4">
          <div class="card admin-card kpi-card border-top-info h-100">
            <div class="card-body">
              <p class="kpi-label mb-1">Ingresos Totales</p>
              <p class="kpi-value mb-0">$<%= totalIngresos.toFixed(2) %></p>
            </div>
          </div>
        </div>
      </div>

      <h3 class="h5 mb-3">Insumos</h3>
      <%- include('partials/tablaProductos.ejs', { productosLista: insumos }) %>

      <h3 class="h5 mb-3">Impresoras</h3>
      <%- include('partials/tablaProductos.ejs', { productosLista: impresoras }) %>
    </main>
    <%- include('partials/footer.ejs') %>
  </body>
</html>
