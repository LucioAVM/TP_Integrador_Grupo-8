<!DOCTYPE html>
<html lang="es">
  <%- include('partials/head.ejs') %>
  <body>
    <%- include('partials/nav.ejs') %>
    <main class="contenedor">
      <h2 class="titulo">Listado de productos</h2>
      <a href="/crearProducto" class="btn btn-primary mb-3">+ Nuevo Producto</a>

      <table class="table table-striped table-hover">
        <thead>
          <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Precio</th>
            <th>Categoría</th>
            <th>Tipo</th>
            <!-- Agregado para mostrar el tipo de producto -->
            <th>Activo</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% productos.forEach(producto => { %>
          <tr
            class="<%= producto.activo ? 'table-success' : 'table-danger' %>"
            data-id="<%= producto.id %>"
          >
            <td><%= producto.id %></td>
            <td><%= producto.nombre %></td>
            <td><%= producto.descripcion %></td>
            <td>$<%= producto.precio %></td>
            <td><%= producto.categoria %></td>
            <td><%= producto.tipo %></td>
            <td class="activo"><%= producto.activo ? 'Sí' : 'No' %></td>
            <td>
              <button
                class="btn btn-warning btn-sm editar"
                data-id="<%= producto.id %>"
              >
                Editar
              </button>
              <% if (producto.activo) { %>
              <button
                class="btn btn-danger btn-sm desactivar"
                data-id="<%= producto.id %>"
              >
                Desactivar
              </button>
              <% } else { %>
              <button
                class="btn btn-success btn-sm reactivar"
                data-id="<%= producto.id %>"
              >
                Reactivar
              </button>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </main>
    <%- include('partials/footer.ejs') %>
    <script src="/assets/js/animations/admin.animations.js"></script>
  </body>
</html>
