<!DOCTYPE html>
<html lang="es">
  <%- include('partials/head.ejs') %>
  <body class="bg-dark admin-root">
    <%- include('partials/nav.ejs', { activePage: 'dashboard' }) %>
    <main class="contenedor-editar">
      <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-2 mb-3">
        <div>
          <p class="fenrir-eyebrow mb-1">ABM Productos</p>
          <h1 class="titulo mb-0">Alta de producto</h1>
        </div>
        <a href="/dashboard" class="btn btn-fenrir-secondary btn-sm">
          <i class="bi bi-arrow-left me-1"></i> Volver
        </a>
      </div>

      <form action="/crearProducto" method="POST" enctype="multipart/form-data" class="form-admin">
        <div class="mb-3">
          <label for="nombre" class="form-label">Nombre</label>
          <input type="text" id="nombre" name="nombre" class="form-control" required />
        </div>

        <div class="mb-3">
          <label for="descripcion" class="form-label">Descripción</label>
          <textarea id="descripcion" name="descripcion" rows="4" class="form-control" required></textarea>
        </div>

        <div class="row g-3">
          <div class="col-sm-6">
            <label for="precio" class="form-label">Precio</label>
            <input type="number" id="precio" name="precio" step="0.01" min="0" class="form-control" required />
          </div>
          <div class="col-sm-6">
            <label for="activo" class="form-label">Activo</label>
            <select id="activo" name="activo" class="form-select" required>
              <option value="true" selected>Sí</option>
              <option value="false">No</option>
            </select>
          </div>
        </div>

        <div class="row g-3 mt-0">
          <div class="col-sm-6 mb-3 mb-sm-0">
            <label for="categoria" class="form-label">Categoría</label>
            <select id="categoria" name="categoria" class="form-select" required>
              <option value="">Seleccionar...</option>
              <option value="impresora">Impresora</option>
              <option value="insumo">Insumo</option>
            </select>
          </div>
          <div class="col-sm-6">
            <label for="tipo" class="form-label">Tipo</label>
            <select id="tipo" name="tipo" class="form-select" required>
              <option value="">Seleccionar...</option>
              <option value="filamento">Filamento</option>
              <option value="resina">Resina</option>
              <option value="otro">Otro</option>
            </select>
          </div>
        </div>

        <div class="mb-4">
          <label for="imagen" class="form-label">Imagen</label>
          <input type="file" id="imagen" name="imagen" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
        </div>

        <button type="submit" class="btn btn-admin-primary">
          <i class="bi bi-check2-circle me-1"></i> Guardar producto
        </button>
      </form>
    </main>
    <%- include('partials/footer.ejs') %>
    <script type="module" src="/assets/js/adminThemeInit.js"></script>
  </body>
</html>
