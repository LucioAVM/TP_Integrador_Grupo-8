<!DOCTYPE html>
<html lang="es">
  <head>
    <%- include('../partials/head.ejs') %>
  </head>
  <body>
    <%- include('../partials/nav.ejs') %>
    <main class="container my-4">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4 mb-0">Ventas</h1>
      </div>

      <div class="row g-3">
        <% ventas.forEach(venta => { %>
        <div class="col-12">
          <div class="card shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-center">
              <div>
                <h5 class="card-title mb-1">Venta #<%= venta.id %></h5>
                <p class="mb-0 text-muted">Cliente: <strong><%= venta.nombre_usuario %></strong></p>
                <p class="mb-0"><span class="badge bg-success">Completada</span> Total: <strong>$<%= Number(venta.total).toFixed(2) %></strong></p>
              </div>
              <div>
                <a href="/ventas/<%= venta.id %>" class="btn btn-outline-primary">Ver detalle</a>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </main>
    <%- include('../partials/footer.ejs') %>
  </body>
</html>
