<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Encuesta de Satisfacción - Fenrir 3D</title>
    <link rel="stylesheet" href="/assets/css/styles.css" />
    <link rel="stylesheet" href="/assets/css/tema.css" />
    <link rel="stylesheet" href="/assets/css/header.css" />
    <link rel="stylesheet" href="/assets/css/encuesta.css" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="icon" type="image/png" href="/assets/img/favicon.png" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  </head>
  <body class="bg-dark">
    <header class="bg-light border-bottom mb-4" id="header-container"></header>
    <main class="container encuesta-page mt-4 mb-5">
      <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-7">
          <div class="encuesta-card fenrir-panel">
            <div class="encuesta-inner">
              <p class="fenrir-eyebrow text-center mb-1">Post-compra</p>
              <h1 class="text-center h3 mb-2">Encuesta de satisfacción</h1>
              <p class="text-center encuesta-intro mb-4">Tu opinión nos ayuda a mejorar. Completá los campos indicados.</p>

              <% if (error) { %>
                <div class="alert alert-danger"><%= error %></div>
              <% } %>

              <form id="form-encuesta" action="/encuesta" method="POST" enctype="multipart/form-data" novalidate>
                <div class="mb-4">
                  <label class="form-label" for="puntuacion">Puntuación del servicio (1 al 5)</label>
                  <div class="d-flex align-items-center gap-3 mb-2">
                    <input type="range" class="form-range flex-grow-1" min="1" max="5" step="1" id="puntuacion" name="puntuacion" value="3" required>
                    <output id="puntuacion-valor" class="badge bg-primary fs-6" for="puntuacion">3</output>
                  </div>
                  <div class="d-flex justify-content-between encuesta-scale-hint">
                    <span>1 (Mala)</span>
                    <span>5 (Excelente)</span>
                  </div>
                  <div id="error-puntuacion" class="invalid-feedback d-none"></div>
                </div>

                <div class="mb-4">
                  <label class="form-label" for="email">Correo electrónico</label>
                  <input type="email" name="email" id="email" class="form-control" placeholder="tu@email.com" required>
                  <div id="error-email" class="invalid-feedback d-none"></div>
                </div>

                <div class="mb-4">
                  <label class="form-label" for="comentario">Comentario (opcional)</label>
                  <textarea name="comentario" id="comentario" class="form-control" rows="4" placeholder="Escribí tu comentario..."></textarea>
                </div>

                <div class="mb-4">
                  <label class="form-label" for="imagen">Imagen (opcional)</label>
                  <input type="file" name="imagen" id="imagen" accept="image/jpeg,image/png,image/webp" class="form-control" />
                  <div class="form-text">Formatos: JPG, PNG o WEBP. Máximo 5 MB.</div>
                  <div id="error-imagen" class="invalid-feedback d-none"></div>
                </div>

                <div class="mb-4 form-check">
                  <input type="checkbox" class="form-check-input" name="terminos" id="terminos" required>
                  <label class="form-check-label" for="terminos">Acepto los términos y condiciones</label>
                  <div id="error-terminos" class="invalid-feedback d-none"></div>
                </div>

                <div class="d-grid gap-2 mt-4">
                  <button class="btn btn-primary btn-fenrir-primary btn-lg" type="submit">
                    <i class="bi bi-send me-1"></i> Enviar encuesta
                  </button>
                  <a href="/" class="text-center mt-2 text-decoration-none encuesta-omitir">
                    <i class="bi bi-skip-forward me-1"></i> Omitir
                  </a>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </main>
    <script type="module" src="/assets/js/main.js"></script>
  </body>
</html>
