<!DOCTYPE html>
<html lang="es">
  <%- include('partials/head.ejs') %>
  <body class="bg-dark admin-root">
    <%- include('partials/nav.ejs', { activePage: 'registros' }) %>
    <main class="container mt-4">
      <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-2 mb-4">
        <div>
          <p class="fenrir-eyebrow mb-1">Estadísticas</p>
          <h1 class="admin-page-title h3 mb-0">Registros y estadísticas</h1>
        </div>
        <div>
          <%
            const exportQuery = [];
            if (filtros?.fechaInicio) exportQuery.push(`fechaInicio=${encodeURIComponent(filtros.fechaInicio)}`);
            if (filtros?.fechaFin) exportQuery.push(`fechaFin=${encodeURIComponent(filtros.fechaFin)}`);
            const exportUrl = exportQuery.length
              ? `/admin/exportar-logs?${exportQuery.join('&')}`
              : '/admin/exportar-logs';
          %>
          <a href="<%= exportUrl %>" class="btn btn-fenrir-success">
            <i class="bi bi-file-earmark-excel me-1"></i> Descargar Excel
          </a>
        </div>
      </div>

      <div class="card shadow-sm admin-card mb-4">
        <div class="card-body">
          <form method="GET" action="/registros" class="row g-3 align-items-end">
            <div class="col-md-4">
              <label for="fechaInicio" class="form-label">Desde</label>
              <input type="date" class="form-control" id="fechaInicio" name="fechaInicio" value="<%= filtros?.fechaInicio || '' %>">
            </div>
            <div class="col-md-4">
              <label for="fechaFin" class="form-label">Hasta</label>
              <input type="date" class="form-control" id="fechaFin" name="fechaFin" value="<%= filtros?.fechaFin || '' %>">
            </div>
            <div class="col-md-4 d-flex gap-2">
              <button type="submit" class="btn btn-primary">Filtrar por fecha</button>
              <a href="/registros" class="btn btn-outline-secondary">Limpiar</a>
            </div>
          </form>
          <% if (filtroActivo) { %>
            <p class="small text-muted mb-0 mt-3">
              Mostrando ventas, estadísticas, logs y encuestas
              <% if (filtros?.fechaInicio && filtros?.fechaFin) { %>
                entre <strong><%= filtros.fechaInicio %></strong> y <strong><%= filtros.fechaFin %></strong>.
              <% } else if (filtros?.fechaInicio) { %>
                desde <strong><%= filtros.fechaInicio %></strong>.
              <% } else { %>
                hasta <strong><%= filtros.fechaFin %></strong>.
              <% } %>
            </p>
          <% } %>
        </div>
      </div>

      <div class="row align-items-start">
        <!-- Total recaudado por mes -->
        <div class="col-md-6 mb-4">
          <div class="card shadow-sm admin-card border-top-primary">
            <div class="card-header admin-card-header border-top-primary">
              <h5 class="mb-0">Total recaudado por mes</h5>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover mb-0 table-accent-primary">
                  <thead class="table-light table-head-neutral">
                    <tr>
                      <th>Mes</th>
                      <th>Total recaudado</th>
                      <th>Ventas</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (totalRecaudadoPorMes && totalRecaudadoPorMes.length > 0) { %>
                      <% totalRecaudadoPorMes.forEach(r => { %>
                        <tr>
                          <td><%= new Date(`${r.mes}-01T00:00:00`).toLocaleDateString('es-AR', { month: 'long', year: 'numeric' }) %></td>
                          <td>$<%= Number(r.total_recaudado).toFixed(2) %></td>
                          <td><%= r.total_ventas %></td>
                        </tr>
                      <% }) %>
                    <% } else { %>
                      <tr><td colspan="3" class="text-center">No hay ventas registradas</td></tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <!-- Top 5 Clientes -->
        <div class="col-md-6 mb-4">
          <div class="card shadow-sm admin-card border-top-warning">
            <div class="card-header admin-card-header border-top-warning">
              <h5 class="mb-0">Top 5 Clientes</h5>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover mb-0 table-accent-warning">
                  <thead class="table-light table-head-neutral">
                    <tr>
                      <th>Cliente</th>
                      <th>Compras</th>
                      <th>Gastado</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (topClientes && topClientes.length > 0) { %>
                      <% topClientes.forEach(c => { %>
                        <tr>
                          <td><%= c.nombre_usuario %></td>
                          <td><%= c.total_compras %></td>
                          <td>$<%= Number(c.total_gastado).toFixed(2) %></td>
                        </tr>
                      <% }) %>
                    <% } else { %>
                      <tr><td colspan="3" class="text-center">No hay compras registradas</td></tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Top 10 Ventas y Top 10 Productos -->
      <div class="row">
        <!-- 10 Ventas más caras -->
        <div class="col-md-6 mb-4">
          <div class="card shadow-sm admin-card border-top-success">
            <div class="card-header admin-card-header border-top-success">
              <h5 class="mb-0">10 Ventas más caras</h5>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover mb-0 table-accent-success">
                  <thead class="table-light table-head-neutral">
                    <tr>
                      <th>ID Venta</th>
                      <% if (filtroActivo) { %><th>Fecha</th><% } %>
                      <th>Cliente</th>
                      <th>Total</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (typeof topVentas !== 'undefined' && topVentas.length > 0) { %>
                      <% topVentas.forEach(v => { %>
                        <tr>
                          <td>#<%= v.id %></td>
                          <% if (filtroActivo) { %>
                            <td><%= v.fecha ? new Date(v.fecha).toLocaleDateString('es-AR') : '-' %></td>
                          <% } %>
                          <td><%= v.nombre_usuario %></td>
                          <td>$<%= Number(v.total).toFixed(2) %></td>
                        </tr>
                      <% }) %>
                    <% } else { %>
                      <tr><td colspan="<%= filtroActivo ? 4 : 3 %>" class="text-center">No hay ventas en el rango seleccionado</td></tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <!-- 10 Productos más vendidos -->
        <div class="col-md-6 mb-4">
          <div class="card shadow-sm admin-card border-top-info">
            <div class="card-header admin-card-header border-top-info">
              <h5 class="mb-0">10 Productos más vendidos</h5>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive table-scrollable">
                <table class="table table-hover mb-0 table-accent-info">
                  <thead class="table-light table-head-neutral">
                    <tr>
                      <th>ID Producto</th>
                      <th>Cantidad Total Vendida</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (typeof topProductos !== 'undefined' && topProductos.length > 0) { %>
                      <% topProductos.forEach(p => { %>
                        <tr>
                          <td>
                            <strong><%= p.nombre %></strong><br>
                            <small class="text-muted">#<%= p.producto_id %></small>
                          </td>
                          <td><%= p.total_vendido %></td>
                        </tr>
                      <% }) %>
                    <% } else { %>
                      <tr><td colspan="2" class="text-center">No hay productos vendidos</td></tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Registros de inicio de sesión -->
      <div class="card shadow-sm admin-card border-top-secondary mb-4">
        <div class="card-header admin-card-header border-top-secondary">
          <h5 class="mb-0">Últimos 10 Registros de inicio de sesión</h5>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-striped mb-0 table-accent-secondary">
              <thead class="table-light table-head-neutral">
                <tr>
                  <th>Timestamp</th>
                  <th>Admin ID</th>
                  <th>Email</th>
                </tr>
              </thead>
              <tbody>
                <% if (registros && registros.length) { %>
                  <% registros.forEach(r => { %>
                    <tr>
                      <td><%= new Date(r.timestamp).toLocaleString('es-AR') %></td>
                      <td><%= r.adminId %></td>
                      <td><%= r.email %></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="3" class="text-center">No hay registros</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="row">
        <div class="col-md-6 mb-4">
          <div class="card shadow-sm admin-card border-top-primary h-100">
            <div class="card-header admin-card-header border-top-primary">
              <h5 class="mb-0">Últimas encuestas recibidas</h5>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover mb-0 table-accent-primary">
                  <thead class="table-light table-head-neutral">
                    <tr>
                      <th>Fecha</th>
                      <th>Email</th>
                      <th>Puntuación</th>
                      <th>Términos</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (ultimasEncuestas && ultimasEncuestas.length) { %>
                      <% ultimasEncuestas.forEach(e => { %>
                        <tr>
                          <td><%= new Date(e.fecha).toLocaleString('es-AR') %></td>
                          <td><%= e.email || '-' %></td>
                          <td><%= e.puntuacion %></td>
                          <td><%= e.terminos ? 'Sí' : 'No' %></td>
                        </tr>
                      <% }) %>
                    <% } else { %>
                      <tr><td colspan="4" class="text-center">No hay encuestas en el rango seleccionado</td></tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <div class="col-md-6 mb-4">
          <div class="card shadow-sm admin-card border-top-danger h-100">
            <div class="card-header admin-card-header border-top-danger">
              <h5 class="mb-0">Encuestas que requieren asistencia (puntuación ≤ 3)</h5>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover mb-0 table-accent-danger">
                  <thead class="table-light table-head-neutral">
                    <tr>
                      <th>Fecha</th>
                      <th>Email</th>
                      <th>Puntuación</th>
                      <th>Comentario</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (encuestasAsistencia && encuestasAsistencia.length) { %>
                      <% encuestasAsistencia.forEach(e => { %>
                        <tr>
                          <td><%= new Date(e.fecha).toLocaleString('es-AR') %></td>
                          <td><%= e.email || '-' %></td>
                          <td><%= e.puntuacion %></td>
                          <td><%= e.comentario ? e.comentario.substring(0, 60) : '-' %></td>
                        </tr>
                      <% }) %>
                    <% } else { %>
                      <tr><td colspan="4" class="text-center">No hay encuestas de baja puntuación en el rango</td></tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
    <%- include('partials/footer.ejs') %>
  </body>
</html>
