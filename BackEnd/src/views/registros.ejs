<!DOCTYPE html>
<html lang="es">
  <%- include('partials/head.ejs') %>
  <body>
    <%- include('partials/nav.ejs') %>
    <main class="container mt-4">
      <div class="d-flex align-items-center justify-content-between mb-4">
        <h1>Registros y Estadísticas</h1>
        <div>
          <a href="/admin/exportar-logs" class="btn btn-success">Descargar Excel (Logs)</a>
        </div>
      </div>

      <!-- Filtro de Fechas -->
      <div class="card mb-4 shadow-sm">
        <div class="card-body">
          <h5 class="card-title">Filtrar Encuestas por Fecha</h5>
          <form action="/registros" method="GET" class="row g-3 align-items-end">
            <div class="col-md-4">
              <label for="fechaInicio" class="form-label">Desde:</label>
              <input type="date" class="form-control" id="fechaInicio" name="fechaInicio" value="<%= filtros?.fechaInicio || '' %>">
            </div>
            <div class="col-md-4">
              <label for="fechaFin" class="form-label">Hasta:</label>
              <input type="date" class="form-control" id="fechaFin" name="fechaFin" value="<%= filtros?.fechaFin || '' %>">
            </div>
            <div class="col-md-4">
              <button type="submit" class="btn btn-primary w-100">Filtrar</button>
            </div>
          </form>
        </div>
      </div>

      <div class="row">
        <!-- Últimas 5 encuestas -->
        <div class="col-md-6 mb-4">
          <div class="card shadow-sm h-100">
            <div class="card-header bg-dark text-white">
              <h5 class="mb-0">Últimas 5 encuestas</h5>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover mb-0">
                  <thead class="table-light">
                    <tr>
                      <th>Fecha</th>
                      <th>Puntuación</th>
                      <th>Comentario</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (ultimasEncuestas && ultimasEncuestas.length > 0) { %>
                      <% ultimasEncuestas.forEach(e => { %>
                        <tr>
                          <td><%= new Date(e.fecha).toLocaleDateString('es-AR') %></td>
                          <td>
                            <% for(let i = 1; i <= 5; i++) { %>
                              <i class="bi bi-star-fill <%= i <= e.puntuacion ? 'text-warning' : 'text-secondary' %>" style="font-size: 0.8rem;"></i>
                            <% } %>
                          </td>
                          <td class="text-truncate" style="max-width: 150px;" title="<%= e.comentario %>">
                            <%= e.comentario || '-' %>
                          </td>
                        </tr>
                      <% }) %>
                    <% } else { %>
                      <tr><td colspan="3" class="text-center">No hay encuestas</td></tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <!-- Encuestas con puntuación más baja -->
        <div class="col-md-6 mb-4">
          <div class="card shadow-sm h-100">
            <div class="card-header bg-danger text-white">
              <h5 class="mb-0">Encuestas con puntuación más baja (≤ 3)</h5>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover mb-0">
                  <thead class="table-light">
                    <tr>
                      <th>Fecha</th>
                      <th>Puntuación</th>
                      <th>Comentario</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (encuestasBajas && encuestasBajas.length > 0) { %>
                      <% encuestasBajas.forEach(e => { %>
                        <tr>
                          <td><%= new Date(e.fecha).toLocaleDateString('es-AR') %></td>
                          <td>
                            <% for(let i = 1; i <= 5; i++) { %>
                              <i class="bi bi-star-fill <%= i <= e.puntuacion ? 'text-warning' : 'text-secondary' %>" style="font-size: 0.8rem;"></i>
                            <% } %>
                          </td>
                          <td class="text-truncate" style="max-width: 150px;" title="<%= e.comentario %>">
                            <%= e.comentario || '-' %>
                          </td>
                        </tr>
                      <% }) %>
                    <% } else { %>
                      <tr><td colspan="3" class="text-center">No hay encuestas bajas</td></tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Top 10 Ventas y Top 10 Productos -->
      <div class="row">
        <!-- 10 Ventas más caras -->
        <div class="col-md-6 mb-4">
          <div class="card shadow-sm h-100">
            <div class="card-header bg-success text-white">
              <h5 class="mb-0">10 Ventas más caras</h5>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover mb-0">
                  <thead class="table-light">
                    <tr>
                      <th>ID Venta</th>
                      <th>Cliente</th>
                      <th>Total</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (typeof topVentas !== 'undefined' && topVentas.length > 0) { %>
                      <% topVentas.forEach(v => { %>
                        <tr>
                          <td>#<%= v.id %></td>
                          <td><%= v.nombre_usuario %></td>
                          <td>$<%= Number(v.total).toFixed(2) %></td>
                        </tr>
                      <% }) %>
                    <% } else { %>
                      <tr><td colspan="3" class="text-center">No hay ventas registradas</td></tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <!-- 10 Productos más vendidos -->
        <div class="col-md-6 mb-4">
          <div class="card shadow-sm h-100">
            <div class="card-header bg-info text-white">
              <h5 class="mb-0">10 Productos más vendidos</h5>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover mb-0">
                  <thead class="table-light">
                    <tr>
                      <th>ID Producto</th>
                      <th>Cantidad Total Vendida</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (typeof topProductos !== 'undefined' && topProductos.length > 0) { %>
                      <% topProductos.forEach(p => { %>
                        <tr>
                          <td>#<%= p.producto_id %></td>
                          <td><%= p.dataValues.total_vendido %></td>
                        </tr>
                      <% }) %>
                    <% } else { %>
                      <tr><td colspan="2" class="text-center">No hay productos vendidos</td></tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Registros de inicio de sesión -->
      <div class="card shadow-sm mb-4">
        <div class="card-header bg-secondary text-white">
          <h5 class="mb-0">Últimos 10 Registros de inicio de sesión</h5>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-striped mb-0">
              <thead class="table-light">
                <tr>
                  <th>Timestamp</th>
                  <th>Admin ID</th>
                  <th>Email</th>
                </tr>
              </thead>
              <tbody>
                <% if (registros && registros.length) { %>
                  <% registros.forEach(r => { %>
                    <tr>
                      <td><%= new Date(r.timestamp).toLocaleString('es-AR') %></td>
                      <td><%= r.adminId %></td>
                      <td><%= r.email %></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="3" class="text-center">No hay registros</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
    <%- include('partials/footer.ejs') %>
  </body>
</html>
