<!DOCTYPE html>
<html lang="es">
  <%- include('partials/head.ejs') %>
  <body>
    <%- include('partials/nav.ejs') %>
    <main class="container mt-4">
      <div class="d-flex align-items-center justify-content-between mb-4">
        <h1>Asistencia - Encuestas de Satisfacción</h1>
      </div>
      
      <div class="card shadow-sm">
        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead class="table-dark">
                <tr>
                  <th>ID</th>
                  <th>Fecha</th>
                  <th>Puntuación</th>
                  <th>Comentario</th>
                  <th>Imagen Adjunta</th>
                </tr>
              </thead>
              <tbody>
                <% if (encuestas && encuestas.length > 0) { %>
                  <% encuestas.forEach(encuesta => { %>
                    <tr>
                      <td>#<%= encuesta.id %></td>
                      <td><%= new Date(encuesta.fecha).toLocaleString('es-AR') %></td>
                      <td>
                        <% for(let i = 1; i <= 5; i++) { %>
                          <i class="bi bi-star-fill <%= i <= encuesta.puntuacion ? 'text-warning' : 'text-secondary' %>"></i>
                        <% } %>
                        <span class="ms-1">(<%= encuesta.puntuacion %>/5)</span>
                      </td>
                      <td><%= encuesta.comentario || 'Sin comentario' %></td>
                      <td>
                        <% if (encuesta.imagen) { %>
                          <a href="/uploads/encuestas/<%= encuesta.imagen %>" target="_blank" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-image"></i> Ver Imagen
                          </a>
                        <% } else { %>
                          <span class="text-muted">N/A</span>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="5" class="text-center py-4">No hay encuestas registradas.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
    <%- include('partials/footer.ejs') %>
  </body>
</html>
