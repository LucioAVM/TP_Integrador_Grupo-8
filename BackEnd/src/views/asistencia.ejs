<!DOCTYPE html>
<html lang="es">
  <%- include('partials/head.ejs') %>
  <body class="bg-dark admin-root">
    <%- include('partials/nav.ejs', { activePage: 'asistencia' }) %>
    <main class="container mt-4">
      <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
          <p class="fenrir-eyebrow mb-1">Encuestas</p>
          <h1 class="admin-page-title h3 mb-0">Asistencia — encuestas</h1>
        </div>
      </div>

      <div class="card mb-4 shadow-sm admin-card border-top-primary">
        <div class="card-body">
          <h5 class="card-title">Filtrar Encuestas por Fecha</h5>
          <form action="/asistencia" method="GET" class="row g-3 align-items-end">
            <div class="col-md-4">
              <label for="fechaInicio" class="form-label">Desde:</label>
              <input type="date" class="form-control" id="fechaInicio" name="fechaInicio" value="<%= filtros?.fechaInicio || '' %>">
            </div>
            <div class="col-md-4">
              <label for="fechaFin" class="form-label">Hasta:</label>
              <input type="date" class="form-control" id="fechaFin" name="fechaFin" value="<%= filtros?.fechaFin || '' %>">
            </div>
            <div class="col-md-4 d-flex gap-2">
              <button type="submit" class="btn btn-primary w-100">Filtrar</button>
              <a href="/asistencia" class="btn btn-outline-secondary w-100">Limpiar</a>
            </div>
          </form>
        </div>
      </div>

      <div class="row g-4 align-items-start">
        <div class="col-12 col-xl-6">
          <div class="card shadow-sm admin-card border-top-primary h-100">
            <div class="card-header admin-card-header border-top-primary">
              <h5 class="mb-0">Últimas 5 encuestas</h5>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive w-100">
                <table class="table table-hover align-middle mb-0 table-accent-primary">
                  <thead class="table-light table-head-neutral">
                    <tr>
                      <th>ID</th>
                      <th>Fecha</th>
                      <th>Email</th>
                      <th>Términos</th>
                      <th>Puntuación</th>
                      <th>Comentario</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (ultimasEncuestas && ultimasEncuestas.length > 0) { %>
                      <% ultimasEncuestas.forEach(encuesta => { %>
                        <tr>
                          <td>#<%= encuesta.id %></td>
                          <td><%= new Date(encuesta.fecha).toLocaleString('es-AR') %></td>
                          <td><%= encuesta.email || 'No provisto' %></td>
                          <td><%= encuesta.terminos ? 'Aceptados' : 'No aceptados' %></td>
                          <td>
                            <% for(let i = 1; i <= 5; i++) { %>
                              <i class="bi bi-star-fill <%= i <= encuesta.puntuacion ? 'text-warning' : 'text-secondary' %>"></i>
                            <% } %>
                            <span class="ms-1">(<%= encuesta.puntuacion %>/5)</span>
                          </td>
                          <td><%= encuesta.comentario || 'Sin comentario' %></td>
                        </tr>
                      <% }) %>
                    <% } else { %>
                      <tr>
                        <td colspan="6" class="text-center py-4">No hay encuestas registradas.</td>
                      </tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12 col-xl-6">
          <div class="card shadow-sm admin-card border-top-danger h-100">
            <div class="card-header admin-card-header border-top-danger">
              <h5 class="mb-0">Encuestas con puntuación más baja (≤ 3)</h5>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive w-100">
                <table class="table table-hover align-middle mb-0 table-accent-danger">
                  <thead class="table-light table-head-neutral">
                    <tr>
                      <th>ID</th>
                      <th>Fecha</th>
                      <th>Email</th>
                      <th>Términos</th>
                      <th>Puntuación</th>
                      <th>Comentario</th>
                      <th>Imagen</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (encuestasBajas && encuestasBajas.length > 0) { %>
                      <% encuestasBajas.forEach(encuesta => { %>
                        <tr>
                          <td>#<%= encuesta.id %></td>
                          <td><%= new Date(encuesta.fecha).toLocaleString('es-AR') %></td>
                          <td><%= encuesta.email || 'No provisto' %></td>
                          <td><%= encuesta.terminos ? 'Aceptados' : 'No aceptados' %></td>
                          <td>
                            <% for(let i = 1; i <= 5; i++) { %>
                              <i class="bi bi-star-fill <%= i <= encuesta.puntuacion ? 'text-warning' : 'text-secondary' %>"></i>
                            <% } %>
                            <span class="ms-1">(<%= encuesta.puntuacion %>/5)</span>
                          </td>
                          <td><%= encuesta.comentario || 'Sin comentario' %></td>
                          <td>
                            <% if (encuesta.imagen) { %>
                              <a href="<%= encuesta.imagen %>" target="_blank" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-image"></i> Ver imagen
                              </a>
                            <% } else { %>
                              <span class="text-muted">N/A</span>
                            <% } %>
                          </td>
                        </tr>
                      <% }) %>
                    <% } else { %>
                      <tr>
                        <td colspan="7" class="text-center py-4">No hay encuestas bajas para el filtro actual.</td>
                      </tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
    <%- include('partials/footer.ejs') %>
  </body>
</html>
